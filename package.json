{
  "name": "@4xeverburga/sugar-skills",
  "version": "0.1.0",
  "description": "SUGAR Skills and Headless Agent. Discover and fix bottlenecks without deployment!",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vitest": "^4.1.9"
  }
}
